# DashScope API Configuration
# Get your key from: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=***

# Model Selection (Optional)
# Default is qwen3.5-vl-max, but you can switch to alternatives:
# - gpt-4o (OpenAI)
# - claude-opus-4-8 (Anthropic)
# - gemini-2.5-pro (Google)
MODEL=qwen3.5-vl-max

# Output Directory (Optional)
# If not set, outputs to the current directory
OUTPUT_DIR=./output

# Logging Level (Optional)
# Set to "true" for detailed debug logs
VERBOSE=false